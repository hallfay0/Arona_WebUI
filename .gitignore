# dependencies
node_modules/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (protect secrets)
.env
.env.*
!.env.example

# build / runtime output
dist/
build/
coverage/
.tmp/
tmp/
.cache/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# test artifacts
*.lcov
.nyc_output/

# uploads / media (optional)
uploads/
media/

# backups
*.bak

# oh-my-claudecode state (session-specific, not project code)
.omc/

# claude code project config (auto-generated per user)
.claude/
CLAUDE.md
.sisyphus/
docs/
openclaw-src/

# trellis: keep project-level specs/workflow/scripts, ignore local runtime state
.trellis/*
!.trellis/.gitignore
!.trellis/.version
!.trellis/config.yaml
!.trellis/workflow.md
!.trellis/worktree.yaml
!.trellis/spec/
!.trellis/spec/**
!.trellis/scripts/
!.trellis/scripts/**
.trellis/tasks/
.trellis/workspace/
.opencode/
.agents/
AGENTS.md
